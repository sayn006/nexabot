generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CLIENT
}

enum AgentType {
  CHATBOT
  VOICE
  WORKFLOW
}

enum AgentStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum MessageRole {
  USER
  ASSISTANT
}

enum PlanType {
  STARTER
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

enum LeadSource {
  CONTACT_FORM
  CHATBOT
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  name             String?
  passwordHash     String
  role             Role           @default(CLIENT)
  stripeCustomerId String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  agents           Agent[]
  subscriptions    Subscription[]
}

model Agent {
  id            String        @id @default(cuid())
  name          String
  type          AgentType     @default(CHATBOT)
  status        AgentStatus   @default(DRAFT)
  webhookUrl    String?
  config        Json?
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Conversation {
  id           String    @id @default(cuid())
  agentId      String
  agent        Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  visitorName  String?
  visitorEmail String?
  messages     Message[]
  createdAt    DateTime  @default(now())
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  createdAt      DateTime     @default(now())
}

model Plan {
  id                   String              @id @default(cuid())
  name                 String
  slug                 String              @unique
  description          String?
  priceMensuel         Float
  priceAnnuel          Float?
  features             Json                @default("[]")
  active               Boolean             @default(true)
  surDemande           Boolean             @default(false)
  badgeText            String?
  ordre                Int                 @default(0)
  stripeProductId      String?
  stripePriceIdMensuel String?
  stripePriceIdAnnuel  String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  subscriptions        Subscription[]
  subscriptionTokens   SubscriptionToken[]
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String             @unique
  stripePriceId        String
  planType             PlanType
  planId               String?
  customPlan           Plan?              @relation(fields: [planId], references: [id])
  status               SubscriptionStatus @default(ACTIVE)
  frequence            String             @default("mensuel")
  email                String?
  nomComplet           String?
  societe              String?
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  createdAt            DateTime           @default(now())
}

model SubscriptionToken {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  planId    String
  userId    String?
  email     String?
  frequence String   @default("mensuel")
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  plan      Plan     @relation(fields: [planId], references: [id])
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String
  company   String?
  message   String?
  source    LeadSource @default(CONTACT_FORM)
  createdAt DateTime   @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model SignatureRequest {
  id                   String   @id @default(cuid())
  email                String
  documentName         String
  documentUrl          String?
  signers              Json
  status               String   @default("DRAFT")
  stripePaymentId      String?
  docusealSubmissionId String?
  price                Float    @default(3.0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
